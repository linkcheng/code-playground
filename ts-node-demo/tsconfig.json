{
  "compilerOptions": {
    /* Language and Environment */
    "target": "ES2022",
    "lib": ["ES2022"],

    /* Modules - ES6 import 优先，同时兼容 CommonJS */
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,

    /* Emit - 由 Node.js --experimental-strip-types 直接运行，tsc 仅做类型检查 */
    "noEmit": true,

    /* Type Checking */
    "strict": false,

    /* Completeness */
    "skipLibCheck": true,

    /* Node.js 类型支持 */
    "types": ["node"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
